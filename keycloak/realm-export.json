{
  "id": "demo-realm",
  "realm": "demo-realm",
  "enabled": true,
  "displayName": "Demo SSO Realm",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "browserFlow": "demo-browser",
  "authenticationFlows": [
    {
      "alias": "demo-browser",
      "description": "Browser flow with email OTP as second factor",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-cookie",                  "requirement": "ALTERNATIVE", "priority": 10, "autheticatorFlow": false, "userSetupAllowed": false },
        { "authenticator": "identity-provider-redirector", "requirement": "ALTERNATIVE", "priority": 25, "autheticatorFlow": false, "userSetupAllowed": false },
        { "flowAlias": "demo-browser forms",               "requirement": "ALTERNATIVE", "priority": 30, "autheticatorFlow": true,  "userSetupAllowed": false }
      ]
    },
    {
      "alias": "demo-browser forms",
      "description": "Username/password, then email OTP",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-username-password-form", "requirement": "REQUIRED", "priority": 10, "autheticatorFlow": false, "userSetupAllowed": false },
        { "authenticator": "demo-email-otp",              "requirement": "REQUIRED", "priority": 20, "autheticatorFlow": false, "userSetupAllowed": false }
      ]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "demo-user-provider",
        "providerId": "demo-user-provider",
        "subComponents": {},
        "config": {
          "enabled": ["true"],
          "priority": ["0"],
          "cachePolicy": ["NO_CACHE"]
        }
      }
    ]
  },
  "users": [],
  "clients": [
    {
      "clientId": "app1-client",
      "enabled": true,
      "name": "App1 Client",
      "description": "Frontend for App1",
      "publicClient": true,
      "bearerOnly": false,
      "webOrigins": ["http://localhost:5173", "http://127.0.0.1:5173"],
      "redirectUris": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "baseUrl": "http://localhost:5173/",
      "rootUrl": "http://localhost:5173",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "attributes": { "login_theme": "app-a" },
      "protocolMappers": [
        {
          "name": "realm-roles-flat",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "app2-client",
      "enabled": true,
      "name": "App2 Client",
      "description": "Frontend for App2",
      "publicClient": true,
      "bearerOnly": false,
      "webOrigins": ["http://localhost:5174", "http://127.0.0.1:5174"],
      "redirectUris": ["http://localhost:5174/*", "http://127.0.0.1:5174/*"],
      "baseUrl": "http://localhost:5174/",
      "rootUrl": "http://localhost:5174",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "attributes": { "login_theme": "app-b" },
      "protocolMappers": [
        {
          "name": "realm-roles-flat",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "app3-client",
      "enabled": true,
      "name": "App3 Client",
      "description": "Frontend for App3 (admin-only)",
      "publicClient": true,
      "bearerOnly": false,
      "webOrigins": ["http://localhost:5175", "http://127.0.0.1:5175"],
      "redirectUris": ["http://localhost:5175/*", "http://127.0.0.1:5175/*"],
      "baseUrl": "http://localhost:5175/",
      "rootUrl": "http://localhost:5175",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "attributes": { "login_theme": "app-c" },
      "protocolMappers": [
        {
          "name": "realm-roles-flat",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard user role"
      },
      {
        "name": "admin",
        "description": "Administrator role"
      },
      {
        "name": "client",
        "description": "Client role"
      }
    ]
  }
}