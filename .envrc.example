# Copy this file to `.envrc` and fill in the blanks.
# If you use direnv, run `direnv allow` after copying.
# `.envrc` itself is gitignored so the real values stay out of source control.

# Podman/Docker compatibility (macOS): point compose at the Podman socket.
export DOCKER_HOST="unix://$(podman machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}')"

# Resend API token used by the Email OTP authenticator in keycloak-provider/.
# Get one at https://resend.com/ → API Keys. Leave blank to disable email
# delivery (the OTP still appears in the Keycloak logs as a fallback).
export RESEND_API_TOKEN=""
